PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
# الإنتاج (مثال نفس الدومين الواجهة): CORS_ORIGIN=https://un.flashpointjordan.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=

# رابط المجلد العام /uploads كما يفتحه المتصفح (يجب HTTPS في الإنتاج).
# إن كان الـ API خلف https://un.flashpointjordan.com ويُوجَّه /uploads نحو نفس الـ Node:
#   UPLOADS_PUBLIC_BASE_URL=https://un.flashpointjordan.com/uploads
# أو اضبط فقط جذر الـ backend العام (بدون /api) ويُشتق /uploads تلقائياً:
#   BACKEND_PUBLIC_ORIGIN=https://un.flashpointjordan.com
UPLOADS_PUBLIC_BASE_URL=http://localhost:5000/uploads
BACKEND_PUBLIC_ORIGIN=
# Keep false in both local and production for DB-first parity.
# Set to true only for temporary local troubleshooting when DB is unavailable.
ENABLE_CATEGORIES_JSON_FALLBACK=false

# Auth hardening flags.
# In production keep both enabled.
REQUIRE_EMAIL_VERIFIED=true
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
MODERATION_BLOCKED_KEYWORDS=

# Listing lifecycle policy.
LISTING_DEFAULT_EXPIRY_DAYS=30
LISTING_RENEW_DAYS=30

# اتصل بنا — إرسال عبر Resend من الـ API (POST /api/contact)
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@sooqna.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

