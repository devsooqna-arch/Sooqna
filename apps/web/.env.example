# Copy to `.env.local` in this folder (apps/web).
# Firebase values come from: Firebase Console -> Project settings -> Your app.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Optional
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_AUTH_DEBUG=false

# Backend API base URL
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:5000/api

# Public website origin used for canonical URLs, OpenGraph URLs, and sitemap.
NEXT_PUBLIC_SITE_URL=https://dev.flashpointjordan.com

# Optional sitemap controls.
NEXT_PUBLIC_SITEMAP_LISTINGS_LIMIT=200
NEXT_PUBLIC_SITEMAP_FETCH_TIMEOUT_MS=7000

