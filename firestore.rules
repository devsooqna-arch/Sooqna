rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isUserDocOwner(userId) {
      return isSignedIn() && uid() == userId;
    }

    /** Published listings visible to everyone; drafts visible to owner only. */
    function listingIsPublic() {
      return resource.data.status == 'published'
        && resource.data.deletedAt == null;
    }

    function isListingOwner() {
      return isSignedIn() && resource.data.ownerId == uid();
    }

    function canReadListing() {
      return listingIsPublic() || isListingOwner();
    }

    function isConversationParticipant() {
      return isSignedIn() && uid() in resource.data.participantIds;
    }

    function isConversationParticipantForMessage(conversationId) {
      return isSignedIn()
        && uid() in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    // --- users: own document read/write only (Milestone 1 baseline) ---
    match /users/{userId} {
      allow read, write: if isUserDocOwner(userId);

      match /favorites/{listingId} {
        allow read, write: if isUserDocOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, write: if isUserDocOwner(userId);
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // --- listings: public reads for published; create when signed in; owner updates/deletes ---
    match /listings/{listingId} {
      allow read: if canReadListing();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == uid();
      allow update, delete: if isListingOwner();
    }

    match /conversations/{conversationId} {
      allow read: if isConversationParticipant();
      allow create: if isSignedIn()
        && uid() in request.resource.data.participantIds;
      allow update: if isSignedIn() && uid() in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipantForMessage(conversationId);
        allow create: if isConversationParticipantForMessage(conversationId)
          && request.resource.data.senderId == uid();
        allow update: if isConversationParticipantForMessage(conversationId);
        allow delete: if false;
      }
    }

    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reportedBy == uid();
      allow read: if isSignedIn()
        && resource.data.reportedBy == uid();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
