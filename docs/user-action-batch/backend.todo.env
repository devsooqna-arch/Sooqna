# انسخ هذا الملف إلى backend/sooqna-backend/.env عند التنفيذ النهائي

PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.com

FIREBASE_PROJECT_ID=sooqna-43924
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
ENABLE_CATEGORIES_JSON_FALLBACK=false

UPLOADS_PUBLIC_BASE_URL=https://your-backend-domain.com/uploads

# Week 2 - Auth Hardening
REQUIRE_EMAIL_VERIFIED=true
RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=
